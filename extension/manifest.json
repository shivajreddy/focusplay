{
  "manifest_version": 3,
  "name": "FocusPlay",
  "version": "0.1.0",
  "description": "Companion extension for FocusPlay - per-tab media control",
  "permissions": [
    "tabs",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
